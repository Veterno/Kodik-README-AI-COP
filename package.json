{
  "name": "kodik-readme-ai",
  "version": "1.0.0",
  "description": "Автоматическая генерация README.md с использованием OpenAI-совместимых API и анализом контекста (локальный fallback)",
  "main": "src/index.js",
  "bin": {
    "kodik-readme-ai": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "benchmark": "node scripts/benchmark.js"
  },
  "keywords": [
    "readme",
    "documentation",
    "generator",
    "template"
  ],
  "author": "GigaCode",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.18.1",
    "dotenv": "^16.0.0",
    "js-yaml": "^5.2.1",
    "prompts": "^2.4.2",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "jest": "^29.0.0"
  }
}