{
  "$schema": "https://json.schemastore.org/package",
  "name": "kodik-readme-ai",
  "version": "1.0.0",
  "description": "Автоматическая генерация README.md с использованием OpenAI-совместимых API и анализом контекста (локальный fallback)",
  "main": "src/index.js",
  "bin": {
    "kodik-readme-ai": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "server": "node app.js",
    "dev": "node --watch src/index.js",
    "test": "jest",
    "test:validator": "jest __tests__/localValidator.test.js",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "benchmark": "node scripts/benchmark.js"
  },
  "keywords": [
    "readme",
    "documentation",
    "generator",
    "template"
  ],
  "author": "GigaCode",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.18",
    "axios": "^1.18.1",
    "dotenv": "^16.0.0",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "highlight.js": "^11.11.1",
    "js-yaml": "^5.2.1",
    "marked": "^18.0.5",
    "multer": "^2.2.0",
    "prompts": "^2.4.2",
    "rimraf": "^6.1.3",
    "simple-git": "^3.36.0",
    "slash": "^3.0.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "p-limit": "^3.1.0",
    "yargs": "^17.7.3"
  }
}
