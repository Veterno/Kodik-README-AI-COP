# Путь к проекту (по умолчанию текущая папка)
TARGET_DIR=.

# Включить AI-генерацию (true/false)
USE_AI=true


#Настройки OpenAI-совместимого API (Ollama, OpenAI, Groq, LM Studio, и т.п.)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=llama3.1
OPENAI_TEMPERATURE=0.7
OPENAI_TOP_P=0.9


# Advanced AI Settings
AI_RETRY_ATTEMPTS=3
AI_TIMEOUT=60000
AI_USE_RESPONSE_FORMAT=true

# Параметры сбора контекста из кода
# Максимальное количество файлов, из которых будет извлечён контекст
CODE_CONTEXT_MAX_FILES=100
# Максимальное количество строк, читаемых из каждого файла
CODE_CONTEXT_MAX_LINES=400

# Финальный сканер и перевод
# Включить автоматический перевод разделов (по умолчанию true)
FINAL_SCAN_ENABLED=true
# Язык генерации (на каком языке AI создаст README изначально)
GENERATION_LANGUAGE=ru
# Целевой язык перевода (на какой язык перевести выбранные разделы в конце)
TARGET_LANGUAGE=ru
# Разделы для перевода (через запятую)
TRANSLATE_SECTIONS=Описание,Ключевые возможности
# Пропускать перевод, если в разделе меньше указанного количества слов
SKIP_TRANSLATION_IF_SHORT=20

# --- Логирование ---
# Путь к файлу логов. Если закомментировано, логи в файл не пишутся.
LOG_FILE=logs/app.log
# Уровень логирования: debug, info, warn, error (по умолчанию info)
LOG_LEVEL=info
# Дописывать в файл (true) или перезаписывать (false)
LOG_APPEND=true
# Добавлять временную метку в начало строки
LOG_TIMESTAMP=true
# Формат JSON (построчно)
LOG_JSON=false